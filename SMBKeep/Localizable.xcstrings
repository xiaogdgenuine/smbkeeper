    "格式：服务器/共享名，例如 192.168.1.4/share。共享名后的子目录路径仅用于生成显示名称" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Format: server/share, e.g. 192.168.1.4/share. Any subpath after the share name is used only to generate the display name."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "格式：服务器/共享名，例如 192.168.1.4/share。共享名后的子目录路径仅用于生成显示名称"
          }
        }
      }
